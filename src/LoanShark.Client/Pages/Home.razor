@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>LoanShark by EGT</PageTitle>

<FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" VerticalGap="20" Style="padding: 2rem; text-align: center;">
    <h1 style="font-weight: bold; color: var(--accent-fill-rest);">LoanShark</h1>
    <h4 style="color: var(--neutral-foreground-hint);">Powered by EulerGates Technologies (EGT)</h4>
    
    <p style="max-width: 600px; font-size: 1.2rem; margin-top: 1rem;">
        Empowering communities with seamless, peer-to-peer lending. Borrow capital when you need it, or fund loans to grow your wealth—even on the go.
    </p>

    <AuthorizeView>
        <Authorized>
            <FluentCard Style="padding: 1.5rem; margin-top: 2rem; max-width: 500px; width: 100%; box-sizing: border-box;">
                <h3>Welcome back, @(context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? context.User.Identity?.Name ?? "User")!</h3>
                <p>You are ready to participate in the marketplace.</p>
                <FluentStack Orientation="Orientation.Horizontal" HorizontalGap="10" HorizontalAlignment="HorizontalAlignment.Center" Style="margin-top: 1rem;">
                    <FluentAnchor Href="/loans" Appearance="Appearance.Accent" Style="width: 150px;">
                        View Loans
                    </FluentAnchor>
                    <FluentAnchor Href="/wallet" Appearance="Appearance.Neutral" Style="width: 150px;">
                        My Wallet
                    </FluentAnchor>
                </FluentStack>
            </FluentCard>
        </Authorized>
        <NotAuthorized>
            <FluentCard Style="padding: 1.5rem; margin-top: 2rem; max-width: 500px; width: 100%; box-sizing: border-box;">
                <h3>Get Started</h3>
                <p>Join the community to start borrowing or lending today.</p>
                <FluentAnchor Href="/login" Appearance="Appearance.Accent" Style="margin-top: 1rem; width: 200px;">
                    Login / Register
                </FluentAnchor>
            </FluentCard>
        </NotAuthorized>
    </AuthorizeView>

    <FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center" VerticalGap="10" Style="margin-top: 3rem; color: var(--neutral-foreground-hint);">
        <p><strong>How it works:</strong></p>
        <p>1. Register your account securely.</p>
        <p>2. Fund your wallet or create a loan request.</p>
        <p>3. Community members fund your loan directly.</p>
    </FluentStack>
</FluentStack>
