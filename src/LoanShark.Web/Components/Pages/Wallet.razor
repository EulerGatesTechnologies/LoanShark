@page "/wallet"
@using LoanShark.Web.Services
@inject WalletService WalletService

<h3>My Wallet</h3>

@if (wallet == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <div class="card mb-4">
        <div class="card-body">
            <h4 class="card-title">Balance: $@wallet.Balance</h4>
            
            <div class="mt-3">
                <FluentNumberField @bind-Value="transactionAmount" Style="width: 200px; display: inline-block; margin-right: 8px;" Placeholder="Amount" />
                <FluentButton Appearance="Appearance.Accent" @onclick="DepositAsync">Deposit</FluentButton>
                <FluentButton Appearance="Appearance.Neutral" @onclick="WithdrawAsync">Withdraw</FluentButton>
            </div>
            
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="text-danger mt-2">@errorMessage</div>
            }
        </div>
    </div>

    <h4>Transaction History</h4>
    @if (transactions == null)
    {
        <p><em>Loading transactions...</em></p>
    }
    else if (!transactions.Any())
    {
        <p>No transactions yet.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Type</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tx in transactions)
                {
                    <tr>
                        <td>@tx.Timestamp.ToLocalTime().ToString("g")</td>
                        <td>@tx.Type</td>
                        <td class="@(tx.Direction == "Incoming" ? "text-success" : "text-danger")">
                            @(tx.Direction == "Incoming" ? "+" : "-")$@tx.Amount
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

@code {
    private WalletDto? wallet;
    private List<TransactionDto>? transactions;
    private decimal transactionAmount;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadWalletDataAsync();
    }

    private async Task LoadWalletDataAsync()
    {
        try
        {
            wallet = await WalletService.GetWalletAsync();
            transactions = await WalletService.GetTransactionsAsync();
        }
        catch
        {
            errorMessage = "Failed to load wallet. Make sure you are logged in.";
        }
    }

    private async Task DepositAsync()
    {
        errorMessage = "";
        if (transactionAmount <= 0)
        {
            errorMessage = "Amount must be greater than zero.";
            return;
        }

        var success = await WalletService.DepositAsync(transactionAmount);
        if (success)
        {
            transactionAmount = 0;
            await LoadWalletDataAsync();
        }
        else
        {
            errorMessage = "Deposit failed.";
        }
    }

    private async Task WithdrawAsync()
    {
        errorMessage = "";
        if (transactionAmount <= 0)
        {
            errorMessage = "Amount must be greater than zero.";
            return;
        }

        var success = await WalletService.WithdrawAsync(transactionAmount);
        if (success)
        {
            transactionAmount = 0;
            await LoadWalletDataAsync();
        }
        else
        {
            errorMessage = "Withdrawal failed. Check if you have sufficient funds.";
        }
    }
}
